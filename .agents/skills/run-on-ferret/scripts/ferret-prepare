#!/usr/bin/env bash
set -Eeuo pipefail
source "$(dirname "$0")/ferret-common"
run_id= sha=
while (($#)); do case "$1" in --run-id) run_id=$2; shift 2;; --sha) sha=$2; shift 2;; *) die "unknown argument $1";; esac; done
valid_run_id "$run_id"; valid_sha "$sha"; run=$(run_dir "$run_id")
"${FERRET_SSH[@]}" "REPO=$(q "$FERRET_REPO_ROOT") EXPECTED=$(q "$FERRET_EXPECTED_REMOTE") ROOT=$(q "$FERRET_RUN_ROOT") RUN=$(q "$run") SHA=$(q "$sha") RID=$(q "$run_id") bash -s" <<'SH'
set -Eeuo pipefail
test -d "$REPO/.git"; test "$(git -C "$REPO" remote get-url origin)" = "$EXPECTED"; test ! -e "$RUN"; mkdir -p "$ROOT"; test "$(realpath -m "$(dirname "$RUN")")" = "$(realpath -m "$ROOT")"
git -C "$REPO" fetch --prune origin; git -C "$REPO" cat-file -e "${SHA}^{commit}"
mkdir "$RUN"; trap 'git -C "$REPO" worktree remove --force "$RUN/repo" >/dev/null 2>&1 || true; rmdir "$RUN" >/dev/null 2>&1 || true' ERR
git -C "$REPO" worktree add --detach "$RUN/repo" "$SHA"; mkdir -p "$RUN"/{outputs,logs,control}
REPO="$REPO" RUN="$RUN" SHA="$SHA" RID="$RID" python - <<'PY'
import datetime,json,os,pathlib,subprocess
p=pathlib.Path(os.environ['RUN'])/'manifest.json'; d={'schema_version':1,'run_id':os.environ['RID'],'host':'Ferret','requested_by_host':'Hamster','git_sha':os.environ['SHA'].lower(),'git_remote':subprocess.check_output(['git','-C',os.environ['REPO'],'remote','get-url','origin'],text=True).strip(),'prepared_at':datetime.datetime.now(datetime.timezone.utc).isoformat(),'status':'prepared'}; p.write_text(json.dumps(d,indent=2,sort_keys=True)+'\n')
PY
SH
printf 'prepared %s at %s\n' "$run_id" "$sha"
