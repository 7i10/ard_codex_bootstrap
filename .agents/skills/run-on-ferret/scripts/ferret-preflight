#!/usr/bin/env bash
set -Eeuo pipefail
source "$(dirname "$0")/ferret-common"
repo=$(q "$FERRET_REPO_ROOT"); root=$(q "$FERRET_RUN_ROOT")
"${FERRET_SSH[@]}" "REPO=$repo RUNROOT=$root EXPECTED=$(q "$FERRET_EXPECTED_REMOTE") MAXGPUS=$(q "$FERRET_MAX_GPUS") $(q "$FERRET_PYTHON") -" <<'PY'
import json, os, shutil, socket, subprocess, sys
def run(args):
    return subprocess.run(args, text=True, capture_output=True).stdout.strip()
repo=os.environ['REPO']; root=os.environ['RUNROOT']
gpu=run(['nvidia-smi','--query-gpu=index,name,uuid,memory.total,memory.used,utilization.gpu','--format=csv,noheader']).splitlines() if shutil.which('nvidia-smi') else []
report={'host':socket.gethostname(),'user':os.environ.get('USER'),'gpu_count':len(gpu),'gpu_inventory':gpu,'screen_available':bool(shutil.which('screen')),'flock_available':bool(shutil.which('flock')),'git_available':bool(shutil.which('git')),'python':sys.executable,'repo_available':os.path.isdir(os.path.join(repo,'.git')),'repo_root':repo,'run_root':root}
report['git_remote']=run(['git','-C',repo,'remote','get-url','origin']) if report['repo_available'] else None
report['git_status']=run(['git','-C',repo,'status','--short','--branch']) if report['repo_available'] else None
report['disk_free_bytes']=shutil.disk_usage(os.path.expanduser('~')).free
report['screens']=run(['screen','-ls']) if report['screen_available'] else ''
report['expected_git_remote']=os.environ['EXPECTED']; report['expected_gpu_count']=int(os.environ['MAXGPUS'])
report['ready']=all((report['gpu_count'] >= report['expected_gpu_count'],report['screen_available'],report['flock_available'],report['git_available'],report['repo_available'],report['git_remote']==report['expected_git_remote']))
report['warnings']=[] if report['ready'] else ['required GPU/tool/repository check failed']
print(json.dumps(report,indent=2,sort_keys=True))
raise SystemExit(0 if report['ready'] else 2)
PY
